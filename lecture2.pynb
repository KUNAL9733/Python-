#Type conversions:->converting one data type to another data type
a=int(10)  #explicit conversion(which means internal)                              *Two types of conversions:->(1)Implicit:-> it is internal     
b=int(20.5) #explicit conversion                                                                               (2)Explicit:-> external(force fully)
x="30"
print(type(x)) #str
c=int(x)
print(type(c),c) #(int),30

#Type casting:->converting one data type into another data type.
a=10
b=20.5
c=[1,2,3,4,5]
d=[1,2,3,4,5]
b=int(b)
x="30"
print(c,type(c),d,type(d))
#z=c+d/a+b   #implicit conversion
#print(x,type(x))
c=int(x)
print(type(c),c)

#Shallow copy:->creates a new object that refer the original objects.
#Explicit type conversion
a=int(10)
b=int(20.5000000)
c=int(3*2.99903)
a1=10
a2=20
a3=30
print(type(a),a)
print(type(b),b)
print(type(c),c)
print(type(a1),a1)
print(type(a2),a2)


#conversion to sequences data types.
#list-list[],tuple-tuple(),set-set()
a='Hello Avenger Hello Avenger'
print(a,type(a))
b=list(a)
c=tuple(a)
d=set(a)
print(b,type(b))
print(c,type(c))
print(d,type(d))
