#hash
Li = [1,2,3,"four",[11,12,13]],[2,5],"hello",False
Li = [1,2,3,"four",[11,12,13]],[2,5],"hello",False

# don't try to index past the end of the tuple
# print(Li[4])          # <-- this raised the IndexError
print(Li[3])            # e.g. the last element, or any index < len(Li)

# access a valid position in `Li` so no IndexError occurs
print(Li[0][4][2])      # third element of the inner list inside the first tuple element
# access a valid position in `Li` so no IndexError occurs
print(Li[0][4][2])  # third element of the inner list inside the first tuple element


